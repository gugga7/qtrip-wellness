{
  "kind": "collectionType",
  "collectionName": "activities",
  "info": {
    "singularName": "activity",
    "pluralName": "activities",
    "displayName": "Activity"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "duration": {
      "type": "integer",
      "required": true,
      "min": 0
    },
    "price": {
      "type": "decimal",
      "required": true,
      "min": 0
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "Culture",
        "Food",
        "Adventure",
        "Nature",
        "Relaxation"
      ],
      "required": true
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": true,
      "allowedTypes": ["images"]
    },
    "votes": {
      "type": "integer",
      "default": 0,
      "min": 0
    },
    "destination": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::destination.destination",
      "inversedBy": "activities"
    }
  }
}