# Database
POSTGRES_PASSWORD=postgres
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
SITE_URL=http://localhost:5197
ADDITIONAL_REDIRECT_URLS=
JWT_EXPIRY=3600
DISABLE_SIGNUP=false
API_EXTERNAL_URL=http://127.0.0.1:56321
STUDIO_URL=http://127.0.0.1:56323

# API Keys (replace with your own)
VITE_OPENWEATHER_API_KEY=your_openweather_key
VITE_MAPBOX_TOKEN=your_mapbox_token
VITE_OPENAI_API_KEY=your_openai_key

# App Config
VITE_APP_URL=http://localhost:5197

# Supabase Configuration
VITE_SUPABASE_URL=http://127.0.0.1:56321
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Storage Configuration
VITE_S3_URL=http://127.0.0.1:56321/storage/v1/s3
VITE_S3_ACCESS_KEY=your_s3_access_key
VITE_S3_SECRET_KEY=your_s3_secret_key
VITE_S3_REGION=local

# AI Schedule
VITE_SUPABASE_FUNCTIONS_URL=http://127.0.0.1:56321/functions/v1
